{
  "id": {
    "type": "string",
    "label": "Id"
  },
  "fsyar_dpart": {
    "type": "string",
    "label": "Department",
    "maxLength": 50,
    "minLength": 3,
    "placeholder": "Enter department",
    "required": true
  },
  "fsyar_cname": {
    "type": "string",
    "label": "Fiscal Year",
    "maxLength": 50,
    "minLength": 4,
    "placeholder": "Enter fiscal year",
    "required": true
  },
  "fsyar_stdat": {
    "type": "date",
    "label": "Start Date",
    "placeholder": "Select start date",
    "required": true,
    "default": "new Date() with local format"
  },
  "fsyar_endat": {
    "type": "date",
    "label": "End Date",
    "placeholder": "Select end date",
    "required": true,
    "default": "new Date() with local format"
  },
  "fsyar_stats": {
    "type": "string",
    "label": "Status",
    "maxLength": 50,
    "placeholder": "Enter status",
    "required": true,
    "default": "Open"
  },
  "fsyar_iscur": {
    "type": "boolean",
    "label": "Is Current",
    "default": true
  },
  "fsyar_opbal": {
    "type": "decimal",
    "label": "Opening Balance",
    "default": 0,
    "placeholder": "Enter opening balance",
    "required": true
  },
  "fsyar_clbal": {
    "type": "decimal",
    "label": "Closing Balance",
    "default": 0,
    "placeholder": "Enter closing balance",
    "required": true
  }
}
