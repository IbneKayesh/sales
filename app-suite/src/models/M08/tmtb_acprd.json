{
  "id": {
    "type": "string",
    "label": "Id"
  },
  "acprd_dpart": {
    "type": "string",
    "label": "Department",
    "maxLength": 50,
    "minLength": 3,
    "placeholder": "Enter department",
    "required": true
  },
  "acprd_fsyar": {
    "type": "string",
    "label": "Fiscal Year",
    "maxLength": 50,
    "minLength": 3,
    "placeholder": "Enter FY",
    "required": true
  },
  "acprd_cname": {
    "type": "string",
    "label": "Period Name",
    "maxLength": 50,
    "minLength": 3,
    "placeholder": "Enter period name",
    "required": true
  },
  "acprd_trnno": {
    "type": "string",
    "label": "Period No",
    "maxLength": 12,
    "minLength": 1,
    "placeholder": "Enter period number",
    "required": true
  },
  "acprd_stdat": {
    "type": "date",
    "label": "Start Date",
    "placeholder": "Select start date",
    "required": true,
    "default": "new Date() with local format"
  },
  "acprd_endat": {
    "type": "date",
    "label": "End Date",
    "placeholder": "Select end date",
    "required": true,
    "default": "new Date() with local format"
  },
  "acprd_stats": {
    "type": "string",
    "label": "Status",
    "maxLength": 50,
    "placeholder": "Enter status",
    "required": true,
    "default": "Open"
  },
  "acprd_iscur": {
    "type": "boolean",
    "label": "Is Current",
    "default": true
  },
  "acprd_opbal": {
    "type": "decimal",
    "label": "Opening Balance",
    "default": 0,
    "placeholder": "Enter opening balance",
    "required": true
  },
  "acprd_clbal": {
    "type": "decimal",
    "label": "Closing Balance",
    "default": 0,
    "placeholder": "Enter closing balance",
    "required": true
  }
}
