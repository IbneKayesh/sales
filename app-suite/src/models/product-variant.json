{
  "name": {
    "type": "string",
    "required": false,
    "maxLength": 100,
    "default": "",
    "label": "Variant Name",
    "placeholder": "e.g. Small, Red, Pro"
  },
  "sku": {
    "type": "string",
    "required": false,
    "maxLength": 50,
    "default": "",
    "label": "Variant SKU",
    "placeholder": "e.g. AIU-005-PRO"
  },
  "size": {
    "type": "string",
    "required": false,
    "maxLength": 50,
    "default": "",
    "label": "Size",
    "placeholder": "e.g. 2GB, XL, 10cm"
  },
  "color": {
    "type": "color",
    "required": false,
    "maxLength": 50,
    "default": "",
    "label": "Color",
    "placeholder": "#hex or name"
  },
  "priceAdjustment": {
    "type": "decimal",
    "required": false,
    "default": 0,
    "label": "Price Adj. ($)",
    "placeholder": "0"
  },
  "stock": {
    "type": "integer",
    "required": false,
    "min": 0,
    "default": 0,
    "label": "Stock",
    "placeholder": "0"
  }
}
