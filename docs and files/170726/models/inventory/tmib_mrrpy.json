{
  "mrrpy_pmode": {
    "type": "string",
    "label": "Payment Method Id",
    "maxLength": 50,
    "minLength": 0,
    "placeholder": "Enter payment method id",
    "required": true
  },
  "mrrpy_pydat": {
    "type": "date",
    "label": "Date",
    "maxLength": 50,
    "minLength": 0,
    "placeholder": "Enter payment date",
    "required": true,
    "default": "new Date() with local format"
  },
  "mrrpy_pdamt": {
    "type": "decimal",
    "label": "Value",
    "maxLength": 999999999,
    "minLength": 0,
    "placeholder": "Enter value",
    "required": true
  },
  "mrrpy_notes": {
    "type": "string",
    "label": "Notes",
    "maxLength": 100,
    "minLength": 0,
    "placeholder": "Enter notes",
    "required": false
  }
}
